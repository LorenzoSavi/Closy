@page
@model Closy.Pages.UserProfiles.RegisterModel
@{
    ViewData["Title"] = "Registrati a Closy";
}

<link rel="stylesheet" href="~/css/falling-emojis.css" />

<div class="falling-emojis" id="emojiContainer"></div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="register-card animate__animated animate__fadeInUp">
                <h2 class="text-center mb-4">Crea il tuo account</h2>

                <form method="post">
                    <div class="form-group mb-3">
                        <label for="username">Nome utente</label>
                        <input type="text" class="form-control" id="username" asp-for="Username" required
                               placeholder="Scegli il tuo nome utente">
                        <small class="form-text text-muted">Il nome con cui ti vedranno gli altri utenti</small>
                    </div>

                    <div class="form-group mb-3">
                        <label for="email">Email</label>
                        <input type="email" class="form-control" id="email" asp-for="Email" required
                               placeholder="La tua email">
                        <small class="form-text text-muted">Non la condivideremo con nessuno</small>
                    </div>

                    <div class="form-group mb-3">
                        <label for="password">Password</label>
                        <input type="password" class="form-control" id="password" asp-for="Password" required
                               placeholder="Crea una password sicura"
                               pattern="^(?=.*[A-Za-z])(?=.*\d)[A-Za-z\d]{8,}$">
                        <small class="form-text text-muted">Minimo 8 caratteri, almeno una lettera e un numero</small>
                    </div>

                    <div class="form-group mb-4">
                        <label for="confirmPassword">Conferma Password</label>
                        <input type="password" class="form-control" id="confirmPassword" asp-for="ConfirmPassword" required
                               placeholder="Ripeti la password">
                        <small class="form-text text-muted">Inserisci nuovamente la password per conferma</small>
                    </div>

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <button type="submit" class="btn btn-primary w-100 mb-3 hover-effect">Crea Account</button>
                </form>

                <div class="text-center mt-3">
                    <p>Hai già un account? <a href="/UserProfiles/login" class="text-primary">Accedi</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
    }

    .register-card {
        background: rgba(255, 255, 255, 0.95);
        padding: 2rem;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
        margin-top: 3rem;
    }

    .form-control {
        border-radius: 10px;
        padding: 0.75rem 1rem;
        border: 1px solid #dee2e6;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            box-shadow: 0 0 0 0.2rem rgba(0, 123, 255, 0.15);
            border-color: #80bdff;
        }

    .hover-effect {
        transition: all 0.3s ease;
    }

        .hover-effect:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
        }

    h2 {
        color: #2c3e50;
        font-weight: bold;
    }
</style>

<script>
    const emojis = ['👕', '👔', '👗', '👖', '👠', '👟', '👢', '👞', '🧢', '🧣', '🧤', '🧥'];
    const container = document.getElementById('emojiContainer');

    function createEmoji() {
        const emoji = document.createElement('div');
        emoji.className = 'emoji';
        emoji.textContent = emojis[Math.floor(Math.random() * emojis.length)];
        emoji.style.left = Math.random() * 100 + 'vw';
        emoji.style.animationDuration = Math.random() * 20 + 10 + 's';
        container.appendChild(emoji);

        emoji.addEventListener('animationend', () => {
            emoji.remove();
        });
    }

    setInterval(createEmoji, 1000);
    for (let i = 0; i < 10; i++) {
        createEmoji();
    }
</script>